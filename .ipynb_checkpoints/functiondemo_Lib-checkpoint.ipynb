   "source": [
    "def is_prime(number):\n",
    "\t\"\"\"This function checks whether the given integer number is prime or not!!\n",
    "\tInput: Integer \n",
    "\tOutput: Prime/Not prime\"\"\"\n",
    "\t\n",
    "\tfor i in range(2, number-1):\n",
    "\t\tif(number % i == 0):\n",
    "\t\t\treturn \"Not prime!!\"\n",
    "\t\telse:\n",
    "\t\t\treturn \"Prime!!\""
   ]
  }
 ],
